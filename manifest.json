{
  "manifest_version": 3,
  "name": "Tab Echo",
  "version": "1.0",

  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "assets/mascot.png",
    "48": "assets/mascot.png",
    "128": "assets/mascot.png"
  },

  "permissions": ["storage", "activeTab", "scripting"],

  "host_permissions": ["*://www.google.com/*", "<all_urls>"],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["lib/compromise.min.js", "js/search/detectSearch.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "js/background.js"
  }
}
