{
  "manifest_version": 3,
  "name": "Tab Echo",
  "version": "1.0",

  "action": {
    "default_popup": "popup.html"
  },

  "permissions": ["storage", "activeTab", "scripting"],

  "host_permissions": ["*://www.google.com/*"],
  "content_scripts": [
    {
      "matches": ["*://www.google.com/*"],
      "js": ["js/search/detectSearch.js"],
      "run_at": "document_end"
    }
  ]
}
